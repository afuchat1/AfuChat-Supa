{
  "expo": {
    "name": "AfuChat",
    "slug": "afuchat",
    "version": "2.0.30",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "afuchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/afu-symbol.png",
      "color": "#00BCD4",
      "iosDisplayInForeground": true
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00BCD4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afuchat.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "AfuChat uses the camera to scan QR codes and take photos.",
        "NSContactsUsageDescription": "AfuChat uses contacts to help you find friends.",
        "NSPhotoLibraryUsageDescription": "AfuChat uses your photo library to share images.",
        "NSMicrophoneUsageDescription": "AfuChat uses the microphone for voice messages."
      },
      "associatedDomains": [
        "applinks:afuchat.com",
        "applinks:www.afuchat.com"
      ],
      "buildNumber": "2.0.30"
    },
    "android": {
      "package": "com.afuchat.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_CONTACTS",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "afuchat.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.afuchat.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 2030
    },
    "web": {
      "favicon": "./assets/images/logo.png",
      "bundler": "metro",
      "output": "single",
      "name": "AfuChat",
      "shortName": "AfuChat",
      "description": "Connect, Chat, Discover. Your all-in-one social platform.",
      "themeColor": "#00BCD4",
      "backgroundColor": "#00BCD4"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://afuchat.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AfuChat uses your location to find nearby people and detect your country.",
          "locationWhenInUsePermission": "AfuChat uses your location to find nearby AfuChat users and detect your country."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AfuChat uses the camera to take photos and videos for stories.",
          "microphonePermission": "AfuChat uses the microphone to record video with audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/afu-symbol.png",
          "color": "#00BCD4",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "b4af70bc-1c1b-4337-8892-ffcedbaa3742"
      }
    },
    "owner": "afunew"
  }
}
