{
  "expo": {
    "name": "AfuChat",
    "slug": "afuchat",
    "version": "2.0.1.7",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "afuchat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/afu-symbol.png",
      "color": "#00C2CB",
      "iosDisplayInForeground": true
    },
    "splash": {
      "image": "./assets/images/afu-symbol.png",
      "resizeMode": "contain",
      "backgroundColor": "#00C2CB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afuchat.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "associatedDomains": [
        "applinks:afuchat.com",
        "applinks:www.afuchat.com"
      ]
    },
    "android": {
      "package": "com.afuchat.app",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "afuchat.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.afuchat.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/logo.png",
      "bundler": "metro",
      "output": "single",
      "name": "AfuChat",
      "shortName": "AfuChat",
      "description": "Connect, Chat, Discover. Your all-in-one social platform.",
      "themeColor": "#00C2CB",
      "backgroundColor": "#00C2CB"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://afuchat.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AfuChat uses your location to detect your country automatically.",
          "locationWhenInUsePermission": "AfuChat uses your location to detect your country automatically."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/afu-symbol.png",
          "color": "#00C2CB",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "b55c5d92-7a83-472f-b660-d1838efba5fe"
      }
    },
    "owner": "amkaweesi1"
  }
}
